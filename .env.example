# ============================================================
# .env.example — Configuración del Asistente Tamiel
# ============================================================
# Copia este archivo como .env y completa los valores.
# cp .env.example .env

# --- GROQ API ---
# Obtén tu API key en: https://console.groq.com/keys
GROQ_API_KEY=PON_AQUI_TU_GROQ_API_KEY

# Modelo para transcripción de audio (Whisper en Groq)
# Opciones: whisper-large-v3, whisper-large-v3-turbo, distil-whisper-large-v3-en
GROQ_MODEL_TRANSCRIPTOR=whisper-large-v3

# Modelo para redacción de correos (LLM en Groq)
# Opciones: meta-llama/llama-4-scout-17b-16e-instruct, llama-3.3-70b-versatile, gemma2-9b-it, etc.
GROQ_MODEL_REDACTOR=meta-llama/llama-4-scout-17b-16e-instruct

# ─── Extracción de Conocimiento ─────────────────────────────────
GROQ_MODEL_KNOWLEDGE=meta-llama/llama-4-scout-17b-16e-instruct

# --- TELEGRAM ---
# Token del bot: habla con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=PON_AQUI_TU_TOKEN_DE_TELEGRAM

# Tu chat ID: habla con @userinfobot en Telegram
TELEGRAM_ADMIN_CHAT_ID=123456789

# --- GMAIL API (OAuth2) ---
# Ruta al archivo de credenciales OAuth2 de Google Cloud
# Descárgalo desde: Google Cloud Console → APIs → Credentials → OAuth 2.0 Client IDs
GMAIL_CREDENTIALS_PATH=data/credentials.json

# Ruta donde se almacenará el token de acceso (se genera automáticamente)
GMAIL_TOKEN_PATH=data/token.json

# Tu correo de Gmail (remitente)
GMAIL_REMITENTE=tu_correo@gmail.com

# --- BASE DE DATOS ---
DATABASE_URL=sqlite:///data/usuario.db

# --- CONFIGURACIÓN GENERAL ---
# Máximo de intentos de redacción por correo (iteraciones con feedback)
MAX_REWRITE_ATTEMPTS=5

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Procesamiento de Documentos ────────────────────────────────
DOC_MAX_TOKENS_LLM=8000
DOC_PROCESSING_ENABLED=true
